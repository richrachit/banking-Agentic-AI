{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Debug workflow tests",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": ["discover", "-s", "tests", "-v"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Launch banking web app",
      "type": "debugpy",
      "request": "launch",
      "module": "banking_agents.web_app",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Launch banking API",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "banking_agents.api_app:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8001",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
