# Copy to .env and replace secrets before exposing the service.
CREDIT_BUREAU_HASH_KEY=replace-with-a-long-random-server-secret
BANKING_CORS_ORIGINS=https://banking.example.com
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Use the AI-enabled image only for the one local unified generative model.
BANKING_IMAGE_TARGET=runtime

# Unified generative AI: disabled, local, or hosted.
GENAI_PROVIDER=disabled
GENAI_ALLOWED_PROVIDERS=local,hosted
GENAI_LOCAL_MODEL=/models/qwen2.5-1.5b-instruct
GENAI_HOSTED_ENDPOINT=
GENAI_HOSTED_MODEL=
GENAI_HOSTED_API_KEY=
