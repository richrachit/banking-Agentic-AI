# Copy to .env and replace secrets before exposing the service.
CREDIT_BUREAU_HASH_KEY=replace-with-a-long-random-server-secret
BANKING_CORS_ORIGINS=https://banking.example.com
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Keep these defaults unless the optional Qwen model and suitable hardware have
# been reviewed and provisioned.
BANKING_IMAGE_TARGET=runtime
DOCUMENT_AI_PROVIDER=baseline
DOCUMENT_AI_MODEL=/models/qwen2.5-vl-3b
